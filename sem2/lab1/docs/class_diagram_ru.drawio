        <mxCell id="study_system" parent="1" style="shape=rectangle;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;strokeColor=#000000;fillColor=#ffffff;fontSize=14;" value="СистемаПодготовки (StudySystem)&#xa;-----------------------------&#xa;- студент: Student | None&#xa;- книги: Список&lt;Book&gt;&#xa;- билеты: Список&lt;Ticket&gt;&#xa;- история: Список&lt;str&gt;&#xa;-----------------------------&#xa;+ создать_студента(name, surname, group)&#xa;+ добавить_книгу(title, subject, author, pages)&#xa;+ добавить_билет(number)&#xa;+ добавить_вопрос_в_билет(number, question)&#xa;+ отметить_билет_выученным(number)&#xa;+ запустить_чтение(book_title, minutes, start_time)&#xa;+ запустить_практику(task_count, minutes, start_time)&#xa;+ запустить_тестирование(questions, minutes, start_time)&#xa;+ повторить_билет(ticket_number, minutes, start_time)&#xa;+ статус()&#xa;+ последние_действия(n)&#xa;+ в_словарь() / из_словаря(data)" vertex="1">
          <mxGeometry height="370" width="660" x="760" y="50" as="geometry" />
        </mxCell>
